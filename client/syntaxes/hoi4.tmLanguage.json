{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Hearts of Iron IV",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#keywords"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.hoi4",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.hoi4",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.hoi4",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hoi4",
                    "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.hoi4",
                    "match": "(=|<|>|!|<=|>=)"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.hoi4",
                    "match": "\\b(yes|no)\\b"
                }
            ]
        }
    },
    "scopeName": "source.hoi4"
}