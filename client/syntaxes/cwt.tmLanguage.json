{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "CWTools Schema",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#brackets"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#alias-declarations"
        },
        {
            "include": "#keys"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.cwt",
                    "match": "#.*$"
                },
                {
                    "name": "comment.line.double-slash.cwt",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.cwt",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.cwt",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.cwt",
                    "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.cwt",
                    "match": "(=|<|>)"
                }
            ]
        },
        "brackets": {
            "patterns": [
                {
                    "name": "meta.brace.cwt",
                    "match": "[{}]"
                },
                {
                    "name": "meta.bracket.cwt",
                    "match": "[\\[\\]]"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.cwt",
                    "match": "\\b(alias|enums|enum|modifiers|links|link_name|desc|input_scopes|output_scope|prefix|data|from_data|data_source)\\b"
                },
                {
                    "name": "keyword.other.cwt",
                    "match": "\\b(scope|push_scope|cardinality|error_if_only_match|severity)\\b"
                },
                {
                    "name": "keyword.other.cwt",
                    "match": "\\b(yes|no|any|ignore_field)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.cwt",
                    "match": "\\b(int|float|bool|localisation|string|variable|array|scalar|bindable_loc|character_name|tech_effect)\\b"
                },
                {
                    "name": "support.type.cwt",
                    "match": "\\b(alias_name|alias_match_left|single_alias_right|value_set)\\b"
                }
            ]
        },
        "alias-declarations": {
            "patterns": [
                {
                    "name": "meta.alias.cwt",
                    "begin": "(alias)\\[",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.control.cwt"
                        }
                    },
                    "end": "\\]",
                    "patterns": [
                        {
                            "name": "entity.name.function.cwt",
                            "match": "(trigger|effect):[a-zA-Z0-9_.]+"
                        },
                        {
                            "name": "variable.parameter.cwt",
                            "match": "<[a-zA-Z0-9_]+>"
                        }
                    ]
                }
            ]
        },
        "keys": {
            "patterns": [
                {
                    "name": "variable.other.property.cwt",
                    "match": "\\b[a-zA-Z0-9_]+(?=\\s*(=|<|>))"
                }
            ]
        }
    },
    "scopeName": "source.cwt"
}
